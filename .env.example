# ── Copy this file to .env and fill in your values ────────────────────────────
# Never commit .env to Git — it contains your secret keys.

# ┌─────────────────────────────────────────────────────────────────────────┐
# │  RECOMMENDED: Ollama (fully local, you already have it installed)        │
# │                                                                          │
# │  Just set LLM_PROVIDER=ollama below.                                    │
# │  The app will check if the model exists and pull it automatically.       │
# │  No API key, no internet, no cost.                                       │
# └─────────────────────────────────────────────────────────────────────────┘

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: ollama | groq | huggingface | openai | anthropic | gemini
LLM_PROVIDER=ollama

# ── Ollama (LOCAL — no API key needed) ────────────────────────────────────────
# Ollama must be running. It usually starts automatically after install.
# If not, run: ollama serve
#
# Model options (the app auto-pulls whichever you set here):
#
#   LOW-END DEVICE (< 8GB RAM, slow CPU) — use one of these:
#     phi3:mini      ~2.2 GB  fastest, still capable
#     llama3.2:3b    ~2.0 GB  good quality, fast
#
#   MID-RANGE DEVICE (8-16 GB RAM):
#     llama3.1:8b    ~4.7 GB  best quality (default)
#     mistral:7b     ~4.1 GB  strong instruction following
#
#   HIGH-END DEVICE (16GB+ RAM or GPU):
#     gemma2:9b      ~5.4 GB  strong reasoning
#     llama3.3:70b   ~40 GB   best quality (GPU recommended)
#
# If you see "SessionInfo not initialized" or very slow responses,
# switch to a smaller model like phi3:mini or llama3.2:3b
OLLAMA_MODEL=llama3.2:latest
OLLAMA_HOST=localhost
OLLAMA_PORT=11434

# ── Groq (FREE cloud — recommended if you don't want to use local Ollama) ─────
# Sign up: https://console.groq.com  — no credit card required
# Free tier: 14,400 requests/day, 6,000 tokens/minute
GROQ_API_KEY=gsk_your_groq_key_here

# Groq model options (pick one):
#   llama-3.1-8b-instant     ← fastest, good for Q&A (default)
#   llama-3.3-70b-versatile  ← smarter, better summaries, still free
#   mixtral-8x7b-32768       ← 32k context window, great for long docs
GROQ_MODEL=llama-3.1-8b-instant

# ── HuggingFace Inference API (FREE — backup option) ──────────────────────────
# Sign up: https://huggingface.co → Settings → Access Tokens → New token (read)
# Free tier: rate-limited shared inference
HUGGINGFACE_API_KEY=hf_your_token_here

# HuggingFace model options (pick one):
#   mistralai/Mistral-7B-Instruct-v0.3   ← best quality (default)
#   HuggingFaceH4/zephyr-7b-beta         ← good alternative
#   microsoft/Phi-3-mini-4k-instruct     ← very small, very fast
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ── Paid Providers (optional — leave blank if not using) ──────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Embeddings (FREE — runs locally, no API key needed) ───────────────────────
# This model downloads once (~130 MB) and runs on your machine.
# No changes needed here unless you want to switch to OpenAI embeddings.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu

# ── File Limits ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50

# ── RAG Settings ──────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=5

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
# WHERE ALL APP DATA IS STORED (documents, chat_messages, usage_events, feedback).
# Leave BLANK to use a local SQLite file (data/pdf_agent.db) — fine for dev.
# To persist data in Supabase Postgres, set the connection string below.
#
# Get it from: Supabase → Connect → ORM / Session pooler.
#   • Transaction pooler (recommended for serverless/cloud like HF): port 6543
#   • Session pooler (use if you hit prepared-statement errors):     port 5432
# Password: Supabase → Settings → Database → Database password.
#   URL-encode special chars in the password (@ → %40, # → %23, etc.).
#
# DATABASE_URL=postgresql://postgres.<project-ref>:<DB_PASSWORD>@aws-1-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.luqtbqfjdatnjebombpo:REDACTED_DB_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
# PdfAgent@supa
# ── Supabase auth (required for login/signup) ─────────────────────────────────
# Backend verifies JWTs via the JWKS endpoint ({SUPABASE_URL}/auth/v1/.well-known/jwks.json),
# so only SUPABASE_URL is required for newer projects using asymmetric signing keys.
SUPABASE_URL=https://luqtbqfjdatnjebombpo.supabase.co
# Optional legacy fallback — only needed for old projects still signing with HS256:
SUPABASE_JWT_SECRET=
# Optional — admin/server-side use only. Never expose in the frontend.
SUPABASE_SERVICE_ROLE_KEY=REDACTED_SERVICE_ROLE_KEY

# Frontend Supabase keys (injected into React app at runtime by Docker)
# Anon / publishable key: Settings → API → anon/public (a.k.a. publishable key)
VITE_SUPABASE_URL=https://luqtbqfjdatnjebombpo.supabase.co
VITE_SUPABASE_ANON_KEY=REDACTED_ANON_KEY

# ── Security ──────────────────────────────────────────────────────────────────
# DEV ONLY. If true, JWTs are accepted WITHOUT signature verification when
# SUPABASE_JWT_SECRET is unset. MUST be false in production.
ALLOW_INSECURE_AUTH=false

# Max characters accepted in a single chat question.
MAX_QUESTION_LENGTH=4000

# CORS — pin to your exact frontend origin(s), comma-separated.
# e.g. https://app.example.com,https://staging.example.com
CORS_ALLOWED_ORIGINS=
# Optional regex for preview deploys (leave blank to disable). Make it TIGHT —
# e.g. ^https://your-project-[a-z0-9]+\.vercel\.app$  (NOT a bare .*\.vercel\.app)
CORS_ALLOWED_ORIGIN_REGEX=

# Trusted Host header values, comma-separated (blank = allow all).
# e.g. api.example.com,localhost
ALLOWED_HOSTS=

# Reject zip-based Office files that expand beyond this uncompressed:compressed
# ratio (decompression-bomb guard).
MAX_DECOMPRESSION_RATIO=120
